        { "id": 33, "text": "Не перебивал клиента", "yes": "Давал клиенту договорить", "no": "Перебивал, обрывал реплики", "na": null, "where": "весь звонок" },
        { "id": 34, "text": "Вежливо и доброжелательно", "yes": "Доброжелательный, корректный тон", "no": "Грубость, раздражение, давление", "na": null, "where": "весь звонок" }
