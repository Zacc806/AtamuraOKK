        { "id": 7, "text": "Озвучил план разговора", "yes": "Сказал, что сейчас расскажет о ЖК", "no": "План разговора не озвучен", "na": null, "where": "программирование" },
        { "id": 8, "text": "Назвал цель — запись в ОП", "yes": "Обозначил: при интересе запишет в отдел продаж", "no": "Следующий шаг не назван", "na": null, "where": "программирование" },
        { "id": 9, "text": "Получил «да» (КЛЮЧЕВОЙ)", "yes": "Клиент явно согласился: «да», «давайте», «хорошо»", "no": "Согласия не получил или не добился", "na": null, "where": "ответ клиента" }
      ]
