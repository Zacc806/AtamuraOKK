        { "id": 29, "text": "Выяснил контекст возражения", "yes": "Задал уточняющий вопрос и получил ответ / настоял", "no": "Не уточнял / спросил в пустоту и пошёл спорить", "na": "весь блок Н.П., если возражений не было", "where": "отработка" },
        { "id": 30, "text": "Привёл аргумент (цифры/факты)", "yes": "Привёл цифры, факты, сравнение", "no": "Голословно, без аргументов", "na": "весь блок Н.П., если возражений не было", "where": "отработка" },
        { "id": 31, "text": "Вернул к закрытию на встречу", "yes": "После отработки снова позвал на встречу", "no": "Не вернул к КЭВ", "na": "весь блок Н.П., если возражений не было", "where": "отработка" }
