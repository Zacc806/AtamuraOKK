        { "id": 20, "text": "Факты верны (локация, УТП по ЖК)", "yes": "Локация/инфраструктура/УТП названы верно по скрипту ЖК", "no": "Ошибся в фактах / «плавал»", "na": null, "where": "сверка со скриптом ЖК" },
        { "id": 21, "text": "Ответил на все вопросы по продукту", "yes": "Ответил корректно на все вопросы клиента", "no": "Не ответил / ответил неверно", "na": "Клиент вопросов по продукту не задавал", "where": "по ходу разговора" }
      ]
    },
    {
      "id": "closing",
      "name": "6. Резюме + Закрытие на КЭВ",
      "criteria": [
        { "id": 22, "text": "Резюмировал разговор", "yes": "Свёл параметры: комнаты, цель, оплата, ПВ", "no": "Не резюмировал", "na": null, "where": "закрытие" },
        { "id": 23, "text": "Презентовал ценность встречи", "yes": "Объяснил, зачем ехать: планировки, объект, стадия", "no": "Позвал без ценности", "na": null, "where": "закрытие" },
        { "id": 24, "text": "Предложил конкретное время с выбором", "yes": "«сегодня/завтра? 1/2 половина дня?»", "no": "Конкретное время не предложил", "na": null, "where": "закрытие" },
        { "id": 25, "text": "При отказе — повторная попытка закрыть", "yes": "Клиент засомневался — менеджер сделал ещё попытку", "no": "Отказ — менеджер отступил", "na": "Клиент согласился сразу", "where": "закрытие" },
        { "id": 26, "text": "Зафиксировал дату + время записи в ОП", "yes": "Назвал конкретные дату и время", "no": "Договорённость не зафиксирована конкретно", "na": null, "where": "закрытие" },
        { "id": 27, "text": "Follow-up в WhatsApp", "yes": "Сказал, что пришлёт адрес ОП, попросил ответить", "no": "Про WhatsApp/адрес не сказал", "na": null, "where": "закрытие" }
