# AtamuraOKK — environment template. Copy to .env and fill in real values.
# .env is gitignored; NEVER commit real secrets.

# --- App ---
ATAMURAOKK_RELOAD=False
ATAMURAOKK_ENVIRONMENT=prod
ATAMURAOKK_LOG_LEVEL=INFO

# --- Postgres (dashboard reads this DB; schema = the contract) ---
ATAMURAOKK_DB_HOST=localhost
ATAMURAOKK_DB_PORT=5432
ATAMURAOKK_DB_USER=AtamuraOKK
ATAMURAOKK_DB_PASS=AtamuraOKK
ATAMURAOKK_DB_BASE=AtamuraOKK

# --- Bitrix24 inbound webhook (scopes: crm,telephony,disk,user) ---
ATAMURAOKK_BITRIX_WEBHOOK=https://<portal>.bitrix24.kz/rest/<user_id>/<token>/

# --- Object storage (S3-compatible; MinIO in dev) ---
ATAMURAOKK_S3_ENDPOINT_URL=http://localhost:9000
ATAMURAOKK_S3_ACCESS_KEY=minioadmin
ATAMURAOKK_S3_SECRET_KEY=minioadmin
ATAMURAOKK_S3_BUCKET=call-recordings

# --- Transcription: OpenAI gpt-4o-transcribe (Russian) ---
ATAMURAOKK_OPENAI_API_KEY=sk-proj-...
ATAMURAOKK_OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe

# --- Transcription: Yandex SpeechKit (Kazakh / "шала казахский") ---
ATAMURAOKK_YANDEX_API_KEY=
ATAMURAOKK_YANDEX_FOLDER_ID=
ATAMURAOKK_YANDEX_SPEECHKIT_MODEL=general

# --- Scoring: Anthropic Claude Sonnet (handles ru + kk in one model) ---
ATAMURAOKK_ANTHROPIC_API_KEY=sk-ant-api03-...
ATAMURAOKK_ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Scoring config ---
ATAMURAOKK_SCORE_RUBRIC_VERSION=tm_call_v3
ATAMURAOKK_SCORE_PASS_THRESHOLD=75
# Sales-script id enabling the script-deviation dimension (empty = off until Pavel sends scripts).
ATAMURAOKK_SCORE_SCRIPT_VERSION=

# --- WhatsApp (Wazzup) — later phase, optional ---
# ATAMURAOKK_WAZZUP_<phone>=<channel_key>
