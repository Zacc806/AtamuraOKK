# AtamuraOKK — environment configuration example.
# Copy to `.env` and fill in real values. `.env` is gitignored; this file is committed.
# All variables are prefixed ATAMURAOKK_ (a few also accept the bare name shown as alias).

# --- App ---
ATAMURAOKK_HOST=127.0.0.1
ATAMURAOKK_PORT=8000
ATAMURAOKK_WORKERS_COUNT=1
ATAMURAOKK_RELOAD=False
ATAMURAOKK_ENVIRONMENT=dev
ATAMURAOKK_LOG_LEVEL=INFO

# --- Database (Postgres) ---
# Defaults match docker-compose.yml. In compose the host is the db service name.
ATAMURAOKK_DB_HOST=localhost
ATAMURAOKK_DB_PORT=5432
ATAMURAOKK_DB_USER=AtamuraOKK
ATAMURAOKK_DB_PASS=AtamuraOKK
ATAMURAOKK_DB_BASE=AtamuraOKK
ATAMURAOKK_DB_ECHO=False

# --- Bitrix24 (inbound webhook) ---
# Full webhook URL ending with a slash. REQUIRED scopes: crm, telephony, disk, user.
#   https://<portal>.bitrix24.kz/rest/<user_id>/<token>/
# (alias: BITRIX_WEBHOOK)
ATAMURAOKK_BITRIX_WEBHOOK=
ATAMURAOKK_BITRIX_MAX_RETRIES=5
ATAMURAOKK_BITRIX_RETRY_BASE_DELAY=1.0

# --- Groq (production transcription via Whisper + Russian-call scoring) ---
# Free tier; key starts with gsk_. (alias: GROQ_API_KEY)
ATAMURAOKK_GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
ATAMURAOKK_GROQ_WHISPER_MODEL=whisper-large-v3
ATAMURAOKK_GROQ_SCORING_MODEL=llama-3.3-70b-versatile

# --- Yandex (SpeechKit STT for Kazakh transcription; optional YandexGPT scorer) ---
# (aliases: YANDEX_API_KEY, YANDEX_FOLDER_ID)
ATAMURAOKK_YANDEX_API_KEY=
ATAMURAOKK_YANDEX_FOLDER_ID=
ATAMURAOKK_YANDEX_SPEECHKIT_MODEL=general
ATAMURAOKK_YANDEX_GPT_MODEL=yandexgpt/latest

# --- Anthropic (default scorer: Claude Sonnet) ---
# (alias: ANTHROPIC_API_KEY)
ATAMURAOKK_ANTHROPIC_API_KEY=
ATAMURAOKK_ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Scoring ---
# Default scorer: anthropic (Claude) | groq_yandex (language-routed Groq/Yandex).
ATAMURAOKK_SCORE_PROVIDER=anthropic
# Rubrics in scoring/rubrics/: tm_call_v3 (updated call checklist, 21 crit, max 100),
# tm_call_v2 (April), okk_meeting_v1 (ОП meeting, max 50).
ATAMURAOKK_SCORE_RUBRIC_VERSION=tm_call_v3
# Sales-script id for the deviation dimension (file stem in scoring/scripts/);
# empty = script check disabled. Set to the real script when Pavel provides it.
ATAMURAOKK_SCORE_SCRIPT_VERSION=
ATAMURAOKK_SCORE_PASS_THRESHOLD=75
ATAMURAOKK_SCORE_LANG_CONFIDENCE=0.75
ATAMURAOKK_SCORE_MAX_RETRIES=5
ATAMURAOKK_SCORE_RETRY_BASE_DELAY=1.0
ATAMURAOKK_SCORE_CONCURRENCY=4
ATAMURAOKK_TRANSCRIBE_CONCURRENCY=6
ATAMURAOKK_SCORE_MIN_DURATION_SEC=60
ATAMURAOKK_SCORE_MAX_TRANSCRIPT_CHARS=24000

# --- Phase 0 spike (local faster-whisper WER eval; optional) ---
ATAMURAOKK_WHISPER_MODEL=large-v3
ATAMURAOKK_WHISPER_DEVICE=auto
ATAMURAOKK_WHISPER_COMPUTE_TYPE=default
# ATAMURAOKK_SPIKE_DIR=
