# AtamuraOKK — environment template. Copy to `.env` and fill the real values.
#   cp .env.example .env
# Every key is prefixed ATAMURAOKK_ (settings.py, env_prefix). Lines left commented
# fall back to the in-code default; uncomment + set the ones you need to change.
# Items marked [SECRET] must be set for prod and kept out of version control.
# Items marked [PROD] are dev defaults that MUST be overridden before go-live.

# ───────────────────────── Core / runtime ─────────────────────────
ATAMURAOKK_ENVIRONMENT=prod
# ATAMURAOKK_LOG_LEVEL=INFO
# Leave reload OFF in prod (the compose `api` service sets it on for dev only).
ATAMURAOKK_RELOAD=False

# ───────────────────────── Database (Postgres) ────────────────────
# In docker-compose these are injected per-service; host tooling (alembic) reads
# them from here. DB_PASS is [PROD] — also drives POSTGRES_PASSWORD via compose.
ATAMURAOKK_DB_HOST=localhost
ATAMURAOKK_DB_PORT=5433
ATAMURAOKK_DB_USER=AtamuraOKK
ATAMURAOKK_DB_PASS=CHANGEME-strong-db-password   # [SECRET][PROD]
ATAMURAOKK_DB_BASE=AtamuraOKK

# ───────────────────────── Object storage (S3 / MinIO) ────────────
ATAMURAOKK_S3_ENDPOINT_URL=http://localhost:9000
ATAMURAOKK_S3_ACCESS_KEY=CHANGEME-minio-access-key   # [SECRET][PROD]
ATAMURAOKK_S3_SECRET_KEY=CHANGEME-minio-secret-key   # [SECRET][PROD]
# ATAMURAOKK_S3_BUCKET=call-recordings
# ATAMURAOKK_S3_REGION=us-east-1

# ───────────────────────── Bitrix24 ───────────────────────────────
# Inbound webhook: https://<portal>.bitrix24.kz/rest/<user_id>/<token>/
ATAMURAOKK_BITRIX_WEBHOOK=https://example.bitrix24.kz/rest/1/CHANGEME/   # [SECRET]
# Safety latch for the ONLY Bitrix write path (cash-buyer manager alert via
# im.notify.personal.add). Keep False until the webhook token carries the `im`
# scope AND one notification has been smoke-tested against the real portal.
ATAMURAOKK_BITRIX_NOTIFY_ENABLED=False

# ───────────────────────── Transcription (Yandex SpeechKit v3) ─────
ATAMURAOKK_TRANSCRIBE_PROVIDER=yandex
# Path to the service-account authorized-key JSON (Bearer/IAM auth). Mount it next
# to the app and point here; do NOT commit the JSON.
ATAMURAOKK_YANDEX_SA_KEY_FILE=authorized_key.json   # [SECRET]
# KZ-region endpoints (defaults already target KZ; override for the global region).
# ATAMURAOKK_YANDEX_STT_ENDPOINT=stt.api.cloud.yandex.net:443
# ATAMURAOKK_YANDEX_IAM_ENDPOINT=https://iam.api.yandexcloud.kz/iam/v1/tokens
# ATAMURAOKK_YANDEX_OPERATION_ENDPOINT=operation.api.yandexcloud.kz:443
# ATAMURAOKK_YANDEX_STT_MODE=async
# ATAMURAOKK_TRANSCRIBE_CONCURRENCY=2
# API-key fallback (only if not using the SA key file above):
# ATAMURAOKK_YANDEX_SECRET_KEY=   # [SECRET]
# ATAMURAOKK_YANDEX_KEY_ID=

# ───────────────────────── Scoring (Anthropic Claude) ─────────────
ATAMURAOKK_SCORING_PROVIDER=anthropic
ATAMURAOKK_ANTHROPIC_API_KEY=sk-ant-CHANGEME   # [SECRET]
# ATAMURAOKK_ANTHROPIC_SCORING_MODEL=claude-sonnet-4-6
# Auto-scoring is today-only by default; backlog scored on demand via the CLI.
# ATAMURAOKK_SCORE_AUTO_TODAY_ONLY=True
# Post-STT glossary repair (ЖК names / Kazakh addresses). Ships OFF — enable only
# after validating with `python -m AtamuraOKK.spike glossary-sample`.
# ATAMURAOKK_GLOSSARY_CORRECT_ENABLED=False

# ───────────────────────── Redis (distributed dispatch) ───────────
# Injected by compose; set for a non-compose / external Redis.
# ATAMURAOKK_REDIS_URL=redis://localhost:6379/0
# ATAMURAOKK_DISPATCH_INTERVAL_SECONDS=60   # sub-minute cadence must divide 60
# Async pool sizing: keep (dispatcher + stage replicas) * (pool_size + max_overflow)
# under Postgres max_connections.
# ATAMURAOKK_DB_POOL_SIZE=5
# ATAMURAOKK_DB_MAX_OVERFLOW=5

# ───────────────────────── Alerting (Telegram) ────────────────────
# Leave blank and alerts/daily-summary only log. Set both for a working pager.
ATAMURAOKK_TELEGRAM_BOT_TOKEN=   # [SECRET]
ATAMURAOKK_TELEGRAM_CHAT_ID=
# ATAMURAOKK_ALERT_FAILURE_THRESHOLD=5

# ───────────────────────── Companion read API (/api/v1) ───────────
# Shared bearer the sales-companion nginx injects. MUST equal COMPANION_API_TOKEN
# on the companion side. Empty = API fails closed (503). Generate: openssl rand -hex 32
ATAMURAOKK_COMPANION_API_TOKEN=CHANGEME-64-hex   # [SECRET][PROD]
# Static РОП (global head) login code. Generate: openssl rand -hex 32. Distribute
# out-of-band. Empty = static head login disabled (heads only via CLI).
ATAMURAOKK_COMPANION_HEAD_KEY=CHANGEME-head-key   # [SECRET][PROD]
# CRM hygiene screen (/hygiene). Two criteria are config-gated and report
# "not_available" until set: the questionnaire field list and the note template
# marker. Comma-separated UF field names for the "anketa" completeness criterion:
# ATAMURAOKK_COMPANION_ANKETA_FIELDS=UF_CRM_1700000000,UF_CRM_1700000001
# A completed call note must contain this marker to count as templated (empty =
# any non-empty note counts): ATAMURAOKK_COMPANION_NOTE_TEMPLATE_MARKER=Итог
# Open deal untouched longer than this many days = status not maintained (default 14):
# ATAMURAOKK_COMPANION_HYGIENE_STALE_DAYS=14

# ───────────────────────── Reporting / timezone ───────────────────
# ATAMURAOKK_REPORT_TIMEZONE=Asia/Qyzylorda
# ATAMURAOKK_INGEST_MIN_DURATION_SEC=90
